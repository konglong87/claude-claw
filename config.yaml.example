# Claude claw WebSocket Server 配置示例
# 复制此文件为 config.yaml 并填入真实凭证

# WebSocket Server 配置
websocket:
  host: "0.0.0.0"
  port: 8777
  api_key: ""  # 可选，设置后客户端需要认证
  max_connections: 1000
  command_timeout: 60000  # 60秒

# 限流配置
rate_limit:
  enabled: true
  window_ms: 60000  # 60秒时间窗口
  max_requests: 100  # 最多100个请求

# 飞书配置
feishu:
  enabled: false  # 启用飞书渠道
  app_id: "cli_xxxxxxxxxxxx"  # 替换为你的飞书 App ID
  app_secret: "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"  # 替换为你的飞书 App Secret
  encrypt_key: ""  # 可选，用于加密验证
  verification_token: "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"  # 替换为你的验证令牌
  connection_mode: "websocket"  # WebSocket 长连接模式
  heartbeat_interval: 30000  # 心跳间隔 30秒

# 钉钉配置
dingtalk:
  enabled: false  # 启用钉钉渠道
  app_key: "dingxxxxxxxxxxxx"  # 替换为你的钉钉 App Key
  app_secret: "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"  # 替换为你的钉钉 App Secret
  agent_id: ""  # 可选，钉钉应用 Agent ID
  connection_mode: "stream"  # stream 或 webhook

# 微信配置（企业微信）
wechat:
  enabled: false  # 启用微信渠道
  corp_id: "wwxxxxxxxxxxxxxxxx"  # 替换为你的企业微信 Corp ID
  corp_secret: "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"  # 替换为你的企业微信 Corp Secret
  agent_id: "100001"  # 替换为你的应用 Agent ID
  token: "MyToken123"  # 替换为你的 Webhook Token
  encoding_aes_key: ""  # 可选，用于加密模式
  connection_mode: "webhook"  # 企业微信仅支持 webhook 模式

# Webhook 配置（WebSocket 模式下不需要）
webhook:
  enabled: false  # 使用 WebSocket 长连接，不需要 Webhook
  host: "0.0.0.0"
  port: 3000

# ========================================
# Clawhub 配置
# ========================================
clawhub:
  registry_url: https://clawhub.ai
  skills_dir: skills
  lockfile: .clawhub/lock.json
  auto_update: false

  # Clawhub API Token（推荐使用环境变量）
  # 优先级: CLAWHUB_TOKEN > CLAWHUB_AUTH_TOKEN > OPENCLAW_CLAWHUB_TOKEN > 配置文件
  # 获取方式: 在 https://clawhub.ai 注册账号并生成 API Token
  token: ""  # 不推荐在此填写真实 token，建议使用环境变量

# 日志配置
logging:
  level: "info"  # debug, info, warn, error
  file: "claude-code-bot.log"

# Claude Code 配置（支持自定义）
claude:
  # 模型名称（支持 Claude、OpenAI、Qwen 等）
  model: "claude-sonnet-4-6"
  # API Key（支持多个环境变量）
  # 优先级: REAL_API_KEY > ANTHROPIC_API_KEY > CLAUDE_API_KEY > 配置文件
  api_key: ""  # 推荐使用环境变量，不要在此文件中填写真实密钥
  # API Base URL（支持自定义端点）
  # 优先级: REAL_API_BASE > ANTHROPIC_BASE_URL > 配置文件
  api_base: "https://api.anthropic.com"  # 或其他兼容端点
  # 最大生成 token 数（可选）
  max_tokens: 4096
  # 温度参数 0-1（可选，默认 0.7）
  temperature: 0.7
  # 是否启用缓存（可选，默认 true）
  enable_cache: true

# 大模型提供商配置（可选，用于多模型切换）
providers:
  openai:
    api_key: ""  # 推荐使用环境变量 OPENAI_API_KEY
    api_base: "https://api.openai.com/v1"

  qwen:
    api_key: ""  # 推荐使用环境变量 QWEN_API_KEY
    api_base: "https://dashscope.aliyuncs.com/compatible-mode/v1"
    model: "qwen-vl-max"  # 可选: qwen-vl-max, qwen-vl-plus, qwen-vl

# ========================================
# 环境变量配置（优先级最高）
# ========================================
# 说明：
# - config.yaml 的 env 优先级高于 ~/.claude/settings.json
# - 用于项目级别的环境变量统一管理
# - 支持任意环境变量键值对
# - 推荐将敏感信息（API Key、Token等）配置在此处
env:
  # Claude API 配置示例（优先级最高）
  # Anthropic 官方 API
  # ANTHROPIC_API_KEY: "sk-ant-xxxxx"  # 替换为你的真实 API Key
  # ANTHROPIC_BASE_URL: "https://api.anthropic.com"  # API 地址
  # ANTHROPIC_MODEL: "claude-sonnet-4-6"  # 模型名称

  # 或使用自定义端点（例如阿里云通义千问）
  # ANTHROPIC_AUTH_TOKEN: "sk-xxxxx"  # 替换为你的真实认证 Token
  # ANTHROPIC_BASE_URL: "https://your-custom-endpoint.com/v1"  # 自定义 API 地址
  # ANTHROPIC_MODEL: "qwen3.6-plus"  # 自定义模型名称

  # Clawhub Token 配置
  # CLAWHUB_TOKEN: "your-clawhub-token"  # 替换为你的 Clawhub API Token

  # 平台凭证配置（可选）
  # FEISHU_APP_ID: "cli_xxxxxxxxxxxx"
  # FEISHU_APP_SECRET: "xxxxxxxxxxxxxxxx"
  # DINGTALK_APP_KEY: "dingxxxxxxxxxxxx"
  # DINGTALK_APP_SECRET: "xxxxxxxxxxxxxxxx"
  # WECHAT_CORP_ID: "wwxxxxxxxxxxxxxxxx"
  # WECHAT_CORP_SECRET: "xxxxxxxxxxxxxxxx"

  # 其他自定义环境变量
  # CUSTOM_VAR_1: "custom_value_1"
  # CUSTOM_VAR_2: "custom_value_2"

# ========================================
# 配置说明
# ========================================
#
# 1. 环境变量支持:
#    - ANTHROPIC_API_KEY 或 CLAUDE_API_KEY: 覆盖 claude.api_key
#    - ANTHROPIC_BASE_URL: 覆盖 claude.api_base
#    - ANTHROPIC_MODEL: 覆盖 claude.model
#    - CLAWHUB_TOKEN 或 CLAWHUB_AUTH_TOKEN: Clawhub API Token（推荐）
#    - FEISHU_APP_ID, FEISHU_APP_SECRET, FEISHU_VERIFICATION_TOKEN: 飞书配置
#    - DINGTALK_APP_KEY, DINGTALK_APP_SECRET, DINGTALK_AGENT_ID: 钉钉配置
#    - WECHAT_CORP_ID, WECHAT_CORP_SECRET, WECHAT_AGENT_ID, WECHAT_TOKEN: 微信配置
#
# 2. 支持的模型:
#    - Claude 系列: claude-sonnet-4-6, claude-opus-4-6, claude-haiku-4-5
#    - OpenAI 系列: gpt-4, gpt-4-turbo, gpt-3.5-turbo
#    - 通义千问: qwen-vl-max, qwen-vl-plus, qwen-vl
#    - 其他 OpenAI 兼容模型
#
# 3. API Base URL 示例:
#    - Claude 官方: https://api.anthropic.com
#    - OpenAI 官方: https://api.openai.com/v1
#    - 阿里云通义: https://dashscope.aliyuncs.com/compatible-mode/v1
#    - 自定义端点: http://localhost:8000/v1
#
# 4. 推荐配置:
#    - Claude 官方: model="claude-sonnet-4-6", api_base="https://api.anthropic.com"
#    - 通义千问: model="qwen-vl-max", api_base="https://dashscope.aliyuncs.com/compatible-mode/v1"
#    - 本地模型: model="local-model", api_base="http://localhost:8000/v1"
#
# 5. 多平台支持:
#    - 飞书: enabled=true 启用飞书渠道（WebSocket 模式）
#    - 钉钉: enabled=true 启用钉钉渠道（Stream 模式）
#    - 微信: enabled=true 启用企业微信渠道（Webhook 模式）
#
# 6. 安全建议:
#    - 不要在此文件中填写真实的 API Key 和密钥
#    - 使用环境变量或密钥管理系统
#    - config.yaml 文件已加入 .gitignore，不会被提交到 Git
#    - 生产环境建议使用专用的密钥管理服务
#

# ========================================
# OpenClaw 兼容配置（新格式）
# ========================================

channels:
  feishu:
    - app_id: "cli_xxxxxxxxxxxx"
      app_secret: "xxxxxxxxxxxxxxxx"
      enabled: true
      connection_mode: "websocket"
      # 可选配置
      encrypt_key: ""
      verification_token: ""

# Claude API 配置
claude:
  model: "claude-sonnet-4-6"
  api_key: "sk-ant-xxx"
  api_base: "https://api.anthropic.com"
  max_tokens: 4096
  temperature: 0.7
