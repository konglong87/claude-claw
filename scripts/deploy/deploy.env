#!/bin/bash
# 部署环境配置 - 所有部署脚本共享
# 使用方法: source scripts/deploy/deploy.env

# 项目目录 (自动检测)
export BOT_DIR="${BOT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." 2>/dev/null && pwd)}"
if [ ! -d "$BOT_DIR" ]; then
    echo "❌ 无法检测项目目录,请手动设置 BOT_DIR"
    exit 1
fi

# 运行用户
export BOT_USER="${BOT_USER:-$USER}"

# Bun 路径 (自动检测)
export BUN_PATH="${BUN_PATH:-$(which bun 2>/dev/null || echo '/usr/local/bin/bun')}"
if [ ! -x "$BUN_PATH" ]; then
    echo "❌ Bun 未安装或不在 PATH 中: $BUN_PATH"
    echo "   请安装 Bun: curl -fsSL https://bun.sh/install | bash"
    exit 1
fi

# Bun 版本验证
export BUN_VERSION_REQUIRED="${BUN_VERSION_REQUIRED:-1.3.9}"
BUN_VERSION_ACTUAL=$(bun --version 2>/dev/null)
if [ "$BUN_VERSION_ACTUAL" != "$BUN_VERSION_REQUIRED" ]; then
    echo "⚠️  Bun 版本不匹配:"
    echo "   要求: $BUN_VERSION_REQUIRED"
    echo "   实际: $BUN_VERSION_ACTUAL"
    echo "   可能影响运行,建议升级"
fi

# WebSocket 端口
export WS_PORT="${WS_PORT:-8765}"

# Webhook 端口
export WEBHOOK_PORT="${WEBHOOK_PORT:-3000}"

# 服务名称
export SERVICE_NAME="${SERVICE_NAME:-claude-bot}"

# 日志目录
export LOG_DIR="${BOT_DIR}/logs"
mkdir -p "$LOG_DIR" 2>/dev/null || {
    echo "❌ 无法创建日志目录: $LOG_DIR"
    exit 1
}

# 最大失败重启次数
export MAX_FAILS="${MAX_FAILS:-3}"

# 健康检查间隔 (秒)
export CHECK_INTERVAL="${CHECK_INTERVAL:-300}"

# 启动超时 (秒)
export START_TIMEOUT="${START_TIMEOUT:-300}"

# 停止超时 (秒)
export STOP_TIMEOUT="${STOP_TIMEOUT:-30}"

echo "✅ 环境配置加载成功:"
echo "   项目目录: $BOT_DIR"
echo "   运行用户: $BOT_USER"
echo "   Bun路径:  $BUN_PATH"
echo "   WS端口:   $WS_PORT"
echo "   日志目录: $LOG_DIR"